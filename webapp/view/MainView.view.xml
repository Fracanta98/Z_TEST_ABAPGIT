<mvc:View controllerName="zitsstockoverview.controller.MainView"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m">
    <Page id="page" title="{i18n>title}">
                <content>
                

                    
  <VBox id="_IDGenVBox" width="100%">

 
  <VBox id="_IDGenVBox1" class="sapUiSmallMarginBottom" width="100%">

    <Title id="_IDGenTitle1" text="MaterialStock" level="H2" class="sapUiTinyMarginBottom"/>

    <FlexBox
      id="_IDGenFlexBox"
      wrap="Wrap"
      fitContainer="true"
      renderType="Bare"
      alignItems="Center"
      justifyContent="Start"
      class="sapUiTinyMarginBottom">

      <SearchField
        id="materialFilter"
        width="20rem"
        placeholder="Material"
        liveChange=".onMaterialLiveChange"
        search=".onMaterialSearch"
        class="sapUiSmallMarginEnd sapUiSmallMarginBottom"/>

      <SearchField
        id="storageBinFilter"
        width="20rem"
        placeholder="Storage Bin"
        search=".onStorageBinSearch"
        class="sapUiSmallMarginEnd sapUiSmallMarginBottom"/>

      <SearchField
        id="batchFilter"
        width="20rem"
        placeholder="Batch"
        search=".onBatchSearch"
        class="sapUiSmallMarginEnd sapUiSmallMarginBottom"/>

      <Input
        id="storageTypeFrom"
        width="10rem"
        placeholder="Storage Type From"
        liveChange=".onStorageTypeFromLiveChange"
        type="Number"
        class="sapUiSmallMarginEnd sapUiSmallMarginBottom"/>

      <Input
        id="storageTypeTo"
        width="10rem"
        placeholder="Storage Type To"
        liveChange=".onStorageTypeToLiveChange"
        type="Number"
        class="sapUiSmallMarginEnd sapUiSmallMarginBottom"/>

      <SearchField
        id="barcodeFilter"
        width="22rem"
        placeholder="Barcode99"
        search=".onBarcodeSearch"
        class="sapUiSmallMarginEnd sapUiSmallMarginBottom"/>


    </FlexBox>

  </VBox>


  <Table
    id="materialStockTable"
    growing="true"
    growingScrollToLoad="true"
    items="{ path: '/MaterialStock' }">

    <headerToolbar>
      <Toolbar id="_IDGenToolbar" design="Transparent">
        <Title id="_IDGenTitle2" text="Results" level="H3"/>
        <ToolbarSpacer id="_IDGenToolbarSpacer"/>
        <Button id="_IDGenButton" text="SEARCH" icon="sap-icon://search" type="Emphasized" press=".onApplyFilters"/>
        <Button id="_IDGenButton1" text="CLEAR" type="Emphasized" press=".onRefresh"/>
      </Toolbar>
    </headerToolbar>

    <columns>
      <Column id="_IDGenColumn"><Text id="_IDGenText" text="Warehouse"/></Column>
      <Column id="_IDGenColumn1"><Text id="_IDGenText1" text="Material"/></Column>
      <Column id="_IDGenColumn2"><Text id="_IDGenText2" text="Plant"/></Column>
      <Column id="_IDGenColumn3"><Text id="_IDGenText3" text="Storage Loc."/></Column>
      <Column id="_IDGenColumn4"><Text id="_IDGenText4" text="Storage Type"/></Column>
      <Column id="_IDGenColumn5"><Text id="_IDGenText5" text="Storage Bin"/></Column>
      <Column id="_IDGenColumn6"><Text id="_IDGenText6" text="Batch"/></Column>
      <Column id="_IDGenColumn7"><Text id="_IDGenText7" text="Stock Cat."/></Column>
      <Column id="_IDGenColumn8"><Text id="_IDGenText8" text="Special Stock Ind."/></Column>
      <Column id="_IDGenColumn9"><Text id="_IDGenText9" text="Special Stock No."/></Column>
      <Column id="_IDGenColumn10"><Text id="_IDGenText10" text="Storage Unit"/></Column>
      <Column id="_IDGenColumn11"><Text id="_IDGenText11" text="SU Type"/></Column>
      <Column id="_IDGenColumn12"><Text id="_IDGenText12" text="Certificate No."/></Column>
      <Column id="_IDGenColumn13"><Text id="_IDGenText13" text="Goods Recipient Date"/></Column>
      <Column id="_IDGenColumn15" hAlign="End"><Text id="_IDGenText15" text="Available"/></Column>
      <Column id="_IDGenColumn16" hAlign="End"><Text id="_IDGenText16" text="Quantity"/></Column>
      <Column id="_IDGenColumn17"><Text id="_IDGenText17" text="Base Unit"/></Column>
    </columns>

    <items>
      <ColumnListItem id="_IDGenColumnListItem" vAlign="Middle">
        <cells>
          <Text id="_IDGenText18" text="{Warehouse_no}"/>
          <Text id="_IDGenText19" text="{Material}"/>
          <Text id="_IDGenText20" text="{Plant}"/>
          <Text id="_IDGenText21" text="{Storage_location}"/>
          <Text id="_IDGenText22" text="{Storage_type}"/>
          <Text id="_IDGenText23" text="{Storage_bin}"/>
          <Text id="_IDGenText24" text="{Batch}"/>
          <Text id="_IDGenText25" text="{Stock_category}"/>
          <Text id="_IDGenText26" text="{Special_stock_indicator}"/>
          <Text id="_IDGenText27" text="{Special_stock_number}"/>
          <Text id="_IDGenText28" text="{Storage_unit}"/>
          <Text id="_IDGenText29" text="{Storage_unit_type}"/>
          <Text id="_IDGenText30" text="{Certificate_number}"/>
          <Text id="_IDGenText31" text="{Date_of_goods_recipient}"/>

          <ObjectNumber id="_IDGenObjectNumber1" number="{Available_stock}"/>
          <ObjectNumber id="_IDGenObjectNumber2" number="{Quant}" unit="{Base_unit}"/>
          <Text id="_IDGenText33" text="{Base_unit}"/>
        </cells>
      </ColumnListItem>
    </items>

  </Table>

</VBox>


                </content>
    </Page>
</mvc:View>